---
// TEMPORARY logo-selection showcase. Not linked from the site.
// Once a concept is chosen, this page will be removed and the winning mark
// wired into the favicon + navbar.
import "../styles/global.css";

const concepts = [
  {
    id: "ascend-trend",
    name: "A · Ascend",
    desc: "Gradient badge with a white upward trend arrow. Best legibility as a favicon / app icon.",
  },
  {
    id: "chevron-up",
    name: "B · Rise",
    desc: "Stacked upward chevrons — light, dynamic and minimal.",
  },
  {
    id: "arrow-bold",
    name: "C · Apex",
    desc: "Bold solid upward arrow. Strong and simple, reads at any size.",
  },
  {
    id: "growth-bars",
    name: "D · Climb",
    desc: "Ascending bars with a trend arrow — classic growth / analytics feel.",
  },
  {
    id: "hex-arrow",
    name: "E · Vector",
    desc: "Hexagon enclosing an upward arrow — techy and structured.",
  },
];

const gradText =
  "bg-gradient-to-r from-green-600 to-emerald-400 bg-clip-text text-transparent";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logo Concepts — Shareef Solutions</title>
  </head>
  <body class="bg-gray-100">
    <main class="mx-auto max-w-6xl px-6 py-16">
      <header class="mb-12">
        <h1 class="text-3xl font-bold tracking-tight text-gray-900">
          Shareef Solutions — Logo Concepts
        </h1>
        <p class="mt-3 max-w-2xl text-gray-600">
          Five directions, all in the “growth / arrow” theme with a
          green→emerald gradient. Each is shown as a standalone icon, paired with
          the wordmark, and at favicon sizes — on light and dark. Tell me the
          letter you like and I’ll finalize it as the favicon, navbar logo and
          social / app assets (and refine details to taste).
        </p>
      </header>

      <div class="space-y-10">
        {
          concepts.map((c) => (
            <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
              <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
                <h2 class="text-xl font-semibold text-gray-900">{c.name}</h2>
                <p class="text-sm text-gray-500">{c.desc}</p>
              </div>

              <div class="mt-6 grid gap-6 md:grid-cols-2">
                {/* Light */}
                <div class="rounded-xl border border-gray-200 bg-white p-6">
                  <p class="mb-5 text-xs font-medium tracking-widest text-gray-400 uppercase">
                    Light
                  </p>
                  <div class="flex flex-wrap items-center gap-x-8 gap-y-5">
                    <img src={`/logos/${c.id}.svg`} width="72" height="72" alt={c.name} />
                    <div class="flex items-center gap-2.5">
                      <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="" />
                      <span class="text-xl font-bold text-gray-900">
                        Shareef<span class={gradText}> Solutions</span>
                      </span>
                    </div>
                  </div>
                  <div class="mt-6 flex items-end gap-4">
                    <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="32px" />
                    <img src={`/logos/${c.id}.svg`} width="24" height="24" alt="24px" />
                    <img src={`/logos/${c.id}.svg`} width="16" height="16" alt="16px" />
                    <span class="text-xs text-gray-400">favicon 32 / 24 / 16</span>
                  </div>
                </div>

                {/* Dark */}
                <div class="rounded-xl border border-gray-800 bg-gray-950 p-6">
                  <p class="mb-5 text-xs font-medium tracking-widest text-gray-500 uppercase">
                    Dark
                  </p>
                  <div class="flex flex-wrap items-center gap-x-8 gap-y-5">
                    <img src={`/logos/${c.id}.svg`} width="72" height="72" alt={c.name} />
                    <div class="flex items-center gap-2.5">
                      <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="" />
                      <span class="text-xl font-bold text-white">
                        Shareef<span class={gradText}> Solutions</span>
                      </span>
                    </div>
                  </div>
                  <div class="mt-6 flex items-end gap-4">
                    <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="32px" />
                    <img src={`/logos/${c.id}.svg`} width="24" height="24" alt="24px" />
                    <img src={`/logos/${c.id}.svg`} width="16" height="16" alt="16px" />
                    <span class="text-xs text-gray-500">favicon 32 / 24 / 16</span>
                  </div>
                </div>
              </div>
            </section>
          ))
        }
      </div>

      <section class="mt-12 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-gray-900">Wordmark only</h2>
        <p class="mt-1 text-sm text-gray-500">
          Pure text treatment with the gradient applied to “Solutions” — for when
          a symbol isn’t needed.
        </p>
        <div class="mt-6 grid gap-6 md:grid-cols-2">
          <div
            class="flex items-center justify-center rounded-xl border border-gray-200 bg-white p-10 text-3xl font-bold text-gray-900"
          >
            Shareef<span class={gradText}> Solutions</span>
          </div>
          <div
            class="flex items-center justify-center rounded-xl border border-gray-800 bg-gray-950 p-10 text-3xl font-bold text-white"
          >
            Shareef<span class={gradText}> Solutions</span>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
