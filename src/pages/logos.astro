---
// TEMPORARY logo-selection showcase. Not linked from the site.
// Once a concept is chosen, this page will be removed and the winning mark
// wired into the favicon + navbar.
import "../styles/global.css";

const concepts = [
  {
    id: "ascend-trend",
    name: "A · Ascend",
    desc: "Gradient badge with a white upward trend arrow. Best legibility as a favicon / app icon.",
  },
  {
    id: "chevron-up",
    name: "B · Rise",
    desc: "Stacked upward chevrons — light, dynamic and minimal.",
  },
  {
    id: "arrow-bold",
    name: "C · Apex",
    desc: "Bold solid upward arrow. Strong and simple, reads at any size.",
  },
  {
    id: "growth-bars",
    name: "D · Climb",
    desc: "Ascending bars with a trend arrow — classic growth / analytics feel.",
  },
  {
    id: "hex-arrow",
    name: "E · Vector",
    desc: "Hexagon enclosing an upward arrow — techy and structured.",
  },
];

const round2 = [
  {
    id: "liftoff",
    name: "F · Liftoff",
    desc: "Faceted paper plane ascending — “send / launch”, with a folded 3D edge.",
  },
  {
    id: "pixel-arrow",
    name: "G · Pixel",
    desc: "Dot-matrix upward arrow — a pixel / tech feel that’s crisp and modern.",
  },
  {
    id: "bloom",
    name: "H · Bloom",
    desc: "Two overlapping blades rising — organic growth, softer and warmer.",
  },
  {
    id: "iso-cube",
    name: "I · Block",
    desc: "Isometric 3D cube in layered greens — a “solution / building block”.",
  },
  {
    id: "mono-s",
    name: "J · Monogram",
    desc: "Custom “S” badge — your initial as a compact brand mark / app icon.",
  },
];

const round3 = [
  {
    id: "ss-twins",
    name: "K · SS Twins",
    desc: "Two S’s side by side on the gradient badge — clean, reads clearly as “SS”.",
  },
  {
    id: "ss-bond",
    name: "L · SS Bond",
    desc: "Two S’s interlocked / offset — suggests partnership and connection.",
  },
  {
    id: "ss-mirror",
    name: "M · SS Mirror",
    desc: "A mirrored S pair — symmetrical emblem, more abstract and ownable.",
  },
  {
    id: "ss-stack",
    name: "N · SS Stack",
    desc: "One S over the other — a compact stacked monogram.",
  },
  {
    id: "ss-open",
    name: "O · SS Open",
    desc: "Gradient SS with no badge — lighter, works inline next to the wordmark.",
  },
  {
    id: "ss-night",
    name: "P · SS Night",
    desc: "Gradient SS on a dark badge — sleek; great for app icons and dark UIs.",
  },
];

const gradText =
  "bg-gradient-to-r from-green-600 to-emerald-400 bg-clip-text text-transparent";

// NOTE: inner sizing/weight/tracking use inline styles (not Tailwind utilities)
// because class names that live only inside these strings aren't picked up by
// Tailwind's scanner. The gradient `gradText` class IS used as a real attribute
// elsewhere on the page, so it is generated and safe to reuse here.
const wordmarks = [
  {
    name: "Q · Full gradient",
    desc: "Whole wordmark in the gradient — geometric Poppins.",
    font: "'Poppins', sans-serif",
    html: `<span class="${gradText}" style="font-size:30px;font-weight:700">Shareef Solutions</span>`,
  },
  {
    name: "R · Stacked",
    desc: "“Shareef” over a spaced, uppercase “Solutions” — Sora.",
    font: "'Sora', sans-serif",
    html: `<span style="display:flex;flex-direction:column;line-height:1"><span style="font-size:30px;font-weight:800">Shareef</span><span class="${gradText}" style="margin-top:4px;font-size:14px;font-weight:600;text-transform:uppercase;letter-spacing:0.4em">Solutions</span></span>`,
  },
  {
    name: "S · Tagline lockup",
    desc: "Wordmark with a small tracked tagline — Plus Jakarta Sans.",
    font: "'Plus Jakarta Sans', sans-serif",
    html: `<span style="display:flex;flex-direction:column;line-height:1.15"><span style="font-size:30px;font-weight:800">Shareef<span class="${gradText}"> Solutions</span></span><span style="margin-top:6px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.35em;opacity:0.6">Full-Stack Software Agency</span></span>`,
  },
  {
    name: "T · Tech lowercase",
    desc: "Lowercase, domain-style — Space Grotesk. Modern startup feel.",
    font: "'Space Grotesk', sans-serif",
    html: `<span style="font-size:30px;font-weight:500;text-transform:lowercase;letter-spacing:-0.01em">shareef<span class="${gradText}">.solutions</span></span>`,
  },
  {
    name: "U · Dot separator",
    desc: "A gradient dot between the words — Poppins.",
    font: "'Poppins', sans-serif",
    html: `<span style="font-size:30px;font-weight:700">Shareef <span class="${gradText}">• Solutions</span></span>`,
  },
  {
    name: "V · Initials + wordmark",
    desc: "Gradient “SS” paired with a small stacked wordmark — Sora.",
    font: "'Sora', sans-serif",
    html: `<span style="display:flex;align-items:center;gap:12px"><span class="${gradText}" style="font-size:36px;font-weight:800;letter-spacing:-0.03em">SS</span><span style="display:flex;flex-direction:column;line-height:1"><span style="font-size:16px;font-weight:700;letter-spacing:0.15em">SHAREEF</span><span class="${gradText}" style="margin-top:4px;font-size:16px;font-weight:700;letter-spacing:0.15em">SOLUTIONS</span></span></span>`,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logo Concepts — Shareef Solutions</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Poppins:wght@600;700;800&family=Sora:wght@600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-gray-100">
    <main class="mx-auto max-w-6xl px-6 py-16">
      <header class="mb-12">
        <h1 class="text-3xl font-bold tracking-tight text-gray-900">
          Shareef Solutions — Logo Concepts
        </h1>
        <p class="mt-3 max-w-2xl text-gray-600">
          Five directions, all in the “growth / arrow” theme with a
          green→emerald gradient. Each is shown as a standalone icon, paired with
          the wordmark, and at favicon sizes — on light and dark. Tell me the
          letter you like and I’ll finalize it as the favicon, navbar logo and
          social / app assets (and refine details to taste).
        </p>
      </header>

      <h2 class="mb-6 text-sm font-semibold tracking-widest text-gray-400 uppercase">
        Round 1 · classic growth marks
      </h2>
      <div class="space-y-10">
        {
          concepts.map((c) => (
            <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
              <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
                <h2 class="text-xl font-semibold text-gray-900">{c.name}</h2>
                <p class="text-sm text-gray-500">{c.desc}</p>
              </div>

              <div class="mt-6 grid gap-6 md:grid-cols-2">
                {/* Light */}
                <div class="rounded-xl border border-gray-200 bg-white p-6">
                  <p class="mb-5 text-xs font-medium tracking-widest text-gray-400 uppercase">
                    Light
                  </p>
                  <div class="flex flex-wrap items-center gap-x-8 gap-y-5">
                    <img src={`/logos/${c.id}.svg`} width="72" height="72" alt={c.name} />
                    <div class="flex items-center gap-2.5">
                      <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="" />
                      <span class="text-xl font-bold text-gray-900">
                        Shareef<span class={gradText}> Solutions</span>
                      </span>
                    </div>
                  </div>
                  <div class="mt-6 flex items-end gap-4">
                    <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="32px" />
                    <img src={`/logos/${c.id}.svg`} width="24" height="24" alt="24px" />
                    <img src={`/logos/${c.id}.svg`} width="16" height="16" alt="16px" />
                    <span class="text-xs text-gray-400">favicon 32 / 24 / 16</span>
                  </div>
                </div>

                {/* Dark */}
                <div class="rounded-xl border border-gray-800 bg-gray-950 p-6">
                  <p class="mb-5 text-xs font-medium tracking-widest text-gray-500 uppercase">
                    Dark
                  </p>
                  <div class="flex flex-wrap items-center gap-x-8 gap-y-5">
                    <img src={`/logos/${c.id}.svg`} width="72" height="72" alt={c.name} />
                    <div class="flex items-center gap-2.5">
                      <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="" />
                      <span class="text-xl font-bold text-white">
                        Shareef<span class={gradText}> Solutions</span>
                      </span>
                    </div>
                  </div>
                  <div class="mt-6 flex items-end gap-4">
                    <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="32px" />
                    <img src={`/logos/${c.id}.svg`} width="24" height="24" alt="24px" />
                    <img src={`/logos/${c.id}.svg`} width="16" height="16" alt="16px" />
                    <span class="text-xs text-gray-500">favicon 32 / 24 / 16</span>
                  </div>
                </div>
              </div>
            </section>
          ))
        }
      </div>

      <h2 class="mt-14 mb-6 text-sm font-semibold tracking-widest text-green-600 uppercase">
        Round 2 · more distinctive directions
      </h2>
      <div class="space-y-10">
        {
          round2.map((c) => (
            <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
              <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
                <h3 class="text-xl font-semibold text-gray-900">{c.name}</h3>
                <p class="text-sm text-gray-500">{c.desc}</p>
              </div>

              <div class="mt-6 grid gap-6 md:grid-cols-2">
                {/* Light */}
                <div class="rounded-xl border border-gray-200 bg-white p-6">
                  <p class="mb-5 text-xs font-medium tracking-widest text-gray-400 uppercase">
                    Light
                  </p>
                  <div class="flex flex-wrap items-center gap-x-8 gap-y-5">
                    <img src={`/logos/${c.id}.svg`} width="72" height="72" alt={c.name} />
                    <div class="flex items-center gap-2.5">
                      <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="" />
                      <span class="text-xl font-bold text-gray-900">
                        Shareef<span class={gradText}> Solutions</span>
                      </span>
                    </div>
                  </div>
                  <div class="mt-6 flex items-end gap-4">
                    <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="32px" />
                    <img src={`/logos/${c.id}.svg`} width="24" height="24" alt="24px" />
                    <img src={`/logos/${c.id}.svg`} width="16" height="16" alt="16px" />
                    <span class="text-xs text-gray-400">favicon 32 / 24 / 16</span>
                  </div>
                </div>

                {/* Dark */}
                <div class="rounded-xl border border-gray-800 bg-gray-950 p-6">
                  <p class="mb-5 text-xs font-medium tracking-widest text-gray-500 uppercase">
                    Dark
                  </p>
                  <div class="flex flex-wrap items-center gap-x-8 gap-y-5">
                    <img src={`/logos/${c.id}.svg`} width="72" height="72" alt={c.name} />
                    <div class="flex items-center gap-2.5">
                      <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="" />
                      <span class="text-xl font-bold text-white">
                        Shareef<span class={gradText}> Solutions</span>
                      </span>
                    </div>
                  </div>
                  <div class="mt-6 flex items-end gap-4">
                    <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="32px" />
                    <img src={`/logos/${c.id}.svg`} width="24" height="24" alt="24px" />
                    <img src={`/logos/${c.id}.svg`} width="16" height="16" alt="16px" />
                    <span class="text-xs text-gray-500">favicon 32 / 24 / 16</span>
                  </div>
                </div>
              </div>
            </section>
          ))
        }
      </div>

      <h2 class="mt-14 mb-2 text-sm font-semibold tracking-widest text-green-600 uppercase">
        Round 3 · monogram (J) experiments — SS
      </h2>
      <p class="mb-6 max-w-2xl text-sm text-gray-500">
        Variations on the “J” badge using two S’s for Shareef Solutions.
      </p>
      <div class="space-y-10">
        {
          round3.map((c) => (
            <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
              <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
                <h3 class="text-xl font-semibold text-gray-900">{c.name}</h3>
                <p class="text-sm text-gray-500">{c.desc}</p>
              </div>

              <div class="mt-6 grid gap-6 md:grid-cols-2">
                {/* Light */}
                <div class="rounded-xl border border-gray-200 bg-white p-6">
                  <p class="mb-5 text-xs font-medium tracking-widest text-gray-400 uppercase">
                    Light
                  </p>
                  <div class="flex flex-wrap items-center gap-x-8 gap-y-5">
                    <img src={`/logos/${c.id}.svg`} width="72" height="72" alt={c.name} />
                    <div class="flex items-center gap-2.5">
                      <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="" />
                      <span class="text-xl font-bold text-gray-900">
                        Shareef<span class={gradText}> Solutions</span>
                      </span>
                    </div>
                  </div>
                  <div class="mt-6 flex items-end gap-4">
                    <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="32px" />
                    <img src={`/logos/${c.id}.svg`} width="24" height="24" alt="24px" />
                    <img src={`/logos/${c.id}.svg`} width="16" height="16" alt="16px" />
                    <span class="text-xs text-gray-400">favicon 32 / 24 / 16</span>
                  </div>
                </div>

                {/* Dark */}
                <div class="rounded-xl border border-gray-800 bg-gray-950 p-6">
                  <p class="mb-5 text-xs font-medium tracking-widest text-gray-500 uppercase">
                    Dark
                  </p>
                  <div class="flex flex-wrap items-center gap-x-8 gap-y-5">
                    <img src={`/logos/${c.id}.svg`} width="72" height="72" alt={c.name} />
                    <div class="flex items-center gap-2.5">
                      <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="" />
                      <span class="text-xl font-bold text-white">
                        Shareef<span class={gradText}> Solutions</span>
                      </span>
                    </div>
                  </div>
                  <div class="mt-6 flex items-end gap-4">
                    <img src={`/logos/${c.id}.svg`} width="32" height="32" alt="32px" />
                    <img src={`/logos/${c.id}.svg`} width="24" height="24" alt="24px" />
                    <img src={`/logos/${c.id}.svg`} width="16" height="16" alt="16px" />
                    <span class="text-xs text-gray-500">favicon 32 / 24 / 16</span>
                  </div>
                </div>
              </div>
            </section>
          ))
        }
      </div>

      <section class="mt-12 rounded-2xl border-2 border-green-500 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
          <h2 class="text-xl font-semibold text-gray-900">
            Current wordmark — keeping this ✓
          </h2>
          <p class="text-sm text-gray-500">
            Your existing navbar logo. Unchanged — shown for reference.
          </p>
        </div>
        <div class="mt-6 grid gap-6 md:grid-cols-2">
          <div
            class="flex items-center justify-center rounded-xl border border-gray-200 bg-white p-10 text-3xl font-bold text-gray-900"
          >
            Shareef<span class={gradText}> Solutions</span>
          </div>
          <div
            class="flex items-center justify-center rounded-xl border border-gray-800 bg-gray-950 p-10 text-3xl font-bold text-white"
          >
            Shareef<span class={gradText}> Solutions</span>
          </div>
        </div>
      </section>

      <h2 class="mt-14 mb-6 text-sm font-semibold tracking-widest text-green-600 uppercase">
        Round 4 · wordmark styles
      </h2>
      <div class="space-y-10">
        {
          wordmarks.map((w) => (
            <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
              <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
                <h3 class="text-xl font-semibold text-gray-900">{w.name}</h3>
                <p class="text-sm text-gray-500">{w.desc}</p>
              </div>
              <div class="mt-6 grid gap-6 md:grid-cols-2">
                <div
                  class="flex min-h-[120px] items-center justify-center rounded-xl border border-gray-200 bg-white p-8 text-gray-900"
                  style={`font-family:${w.font}`}
                  set:html={w.html}
                />
                <div
                  class="flex min-h-[120px] items-center justify-center rounded-xl border border-gray-800 bg-gray-950 p-8 text-white"
                  style={`font-family:${w.font}`}
                  set:html={w.html}
                />
              </div>
            </section>
          ))
        }
      </div>
    </main>
  </body>
</html>
