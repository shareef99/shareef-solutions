---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Customer Support">
  <div class="pt-24 pb-16">
    <div class="mx-auto max-w-7xl px-6">
      <a
        href="/"
        class="mb-8 inline-flex items-center gap-2 text-sm font-medium text-green-600 transition-colors hover:text-green-700 dark:text-green-400 dark:hover:text-green-300"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="size-4"
        >
          <path
            fill-rule="evenodd"
            d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z"
            clip-rule="evenodd"></path>
        </svg>
        Back to Home
      </a>

      <h1
        class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white"
      >
        Customer Support
      </h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        We're here to help. Reach out to us through any of the channels below.
      </p>

      <div class="mt-12 grid grid-cols-1 gap-12 lg:grid-cols-2">
        <div class="space-y-8">
          <div>
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
              Contact Information
            </h2>
            <p class="mt-2 text-gray-600 dark:text-gray-400">
              Shareef Solutions is a registered software services company in
              India.
            </p>
          </div>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div
                class="rounded-lg bg-green-50 p-2.5 text-green-600 dark:bg-green-950 dark:text-green-400"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">
                  Registered Address
                </p>
                <p class="mt-1 text-gray-600 dark:text-gray-400">
                  Talab Katta, Bhavani Nagar,
                  <br />
                  Hyderabad, Telangana, India
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="rounded-lg bg-green-50 p-2.5 text-green-600 dark:bg-green-950 dark:text-green-400"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Phone</p>
                <p class="mt-1 text-gray-600 dark:text-gray-400">
                  <a
                    href="tel:+917815837564"
                    class="hover:text-green-600 dark:hover:text-green-400"
                  >
                    +91 7815837564
                  </a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="rounded-lg bg-green-50 p-2.5 text-green-600 dark:bg-green-950 dark:text-green-400"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Email</p>
                <p class="mt-1 text-gray-600 dark:text-gray-400">
                  <a
                    href="mailto:nadeemshareef934@gmail.com"
                    class="hover:text-green-600 dark:hover:text-green-400"
                  >
                    nadeemshareef934@gmail.com
                  </a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="rounded-lg bg-green-50 p-2.5 text-green-600 dark:bg-green-950 dark:text-green-400"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">
                  Business Hours
                </p>
                <p class="mt-1 text-gray-600 dark:text-gray-400">
                  Monday – Saturday: 10:00 AM – 7:00 PM IST
                </p>
              </div>
            </div>
          </div>
        </div>

        <form
          id="support-form"
          class="space-y-6 rounded-2xl border border-gray-200 bg-gray-50 p-8 dark:border-gray-800 dark:bg-gray-900"
        >
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
            Send Us a Message
          </h2>
          <div>
            <label
              for="support-name"
              class="mb-2 block text-sm font-medium text-gray-900 dark:text-white"
            >
              Full Name
            </label>
            <input
              type="text"
              id="support-name"
              name="name"
              required
              class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 transition-colors focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:outline-none dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:focus:border-green-400"
              placeholder="Name"
            />
          </div>
          <div>
            <label
              for="support-email"
              class="mb-2 block text-sm font-medium text-gray-900 dark:text-white"
            >
              Email Address
            </label>
            <input
              type="email"
              id="support-email"
              name="email"
              required
              class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 transition-colors focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:outline-none dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:focus:border-green-400"
              placeholder="name@example.com"
            />
          </div>
          <div>
            <label
              for="support-message"
              class="mb-2 block text-sm font-medium text-gray-900 dark:text-white"
            >
              How can we help?
            </label>
            <textarea
              id="support-message"
              name="message"
              rows="5"
              required
              class="w-full resize-none rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 transition-colors focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:outline-none dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:focus:border-green-400"
              placeholder="Describe your issue or question..."></textarea>
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-green-600 px-8 py-3.5 text-sm font-semibold text-white shadow-lg transition-all hover:bg-green-700 hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById("support-form") as HTMLFormElement | null;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const name = (form.elements.namedItem("name") as HTMLInputElement).value;
    const email = (form.elements.namedItem("email") as HTMLInputElement).value;
    const message = (
      form.elements.namedItem("message") as HTMLTextAreaElement
    ).value;
    const subject = encodeURIComponent(`Support Request from ${name}`);
    const body = encodeURIComponent(`Name: ${name}\nEmail: ${email}\n\n${message}`);
    window.location.href = `mailto:nadeemshareef934@gmail.com?subject=${subject}&body=${body}`;
  });
</script>
