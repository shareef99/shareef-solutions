---
const services = [
  {
    title: "Web Development",
    description:
      "High-performance websites and web applications built with modern frameworks, optimized for speed and scalability.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A8.966 8.966 0 0 1 3 12c0-1.264.26-2.467.732-3.558" />`,
  },
  {
    title: "Mobile Development",
    description:
      "Native and cross-platform mobile apps that deliver seamless experiences on iOS and Android devices.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />`,
  },
  {
    title: "UI/UX Design",
    description:
      "User-centered design that combines beautiful interfaces with intuitive experiences to maximize engagement.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42" />`,
  },
  {
    title: "Custom Software",
    description:
      "Tailored software solutions engineered to solve your unique business challenges and drive operational efficiency.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />`,
  },
];
---

<section
  id="services"
  class="bg-white py-20 sm:py-28 dark:bg-gray-950"
  aria-label="Our services"
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p
        class="text-sm font-semibold tracking-widest text-green-600 uppercase dark:text-green-400"
      >
        What We Do
      </p>
      <h2
        class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white"
      >
        Solutions That Deliver Results
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        We combine technical expertise with strategic thinking to build software
        that moves your business forward.
      </p>
    </div>

    <div
      class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4"
    >
      {
        services.map((service) => (
          <div class="group rounded-2xl border border-gray-200 bg-white p-8 transition-all hover:border-green-200 hover:shadow-lg dark:border-gray-800 dark:bg-gray-900 dark:hover:border-green-800">
            <div class="mb-5 inline-flex rounded-xl bg-green-50 p-3 text-green-600 dark:bg-green-950 dark:text-green-400">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-8"
                set:html={service.icon}
              />
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
              {service.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
